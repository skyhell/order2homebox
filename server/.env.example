# order2homebox server configuration — copy to .env and adjust.
# All variables use the O2H_ prefix.

# --- Homebox ---------------------------------------------------------------
O2H_HOMEBOX_URL=http://192.168.1.10:7745
# URL encoded into the QR codes (what phones open when scanning).
# Leave empty to use O2H_HOMEBOX_URL.
O2H_HOMEBOX_PUBLIC_URL=
O2H_HOMEBOX_USERNAME=you@example.com
# Password to log into the Homebox API. Plain text works, but you can store it
# encrypted: run `python -m app.encrypt` and paste the resulting "enc:..." value
# here. The encryption key is kept in data/secret.key (never in .env), so a
# leaked .env alone does not reveal the password.
O2H_HOMEBOX_PASSWORD=secret

# --- Print agent (Raspberry Pi) ---------------------------------------------
O2H_PRINT_AGENT_URL=http://raspberrypi.local:8010
# Also accepts an "enc:..." value from `python -m app.encrypt`.
O2H_PRINT_AGENT_API_KEY=

# --- Web UI ------------------------------------------------------------------
O2H_WEB_USER=admin
# Generate with: python -m app.hashpw
O2H_WEB_PASSWORD_HASH=
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
O2H_SECRET_KEY=
O2H_DEFAULT_LANGUAGE=de

# --- Labels -------------------------------------------------------------------
O2H_LABEL_SHOW_ASSET_ID=true
O2H_LABEL_QR_PER_ROW=2

# --- Scraping -------------------------------------------------------------------
O2H_AMAZON_DOMAIN=www.amazon.de
O2H_SCRAPER_HEADLESS=true
O2H_SCRAPER_TIMEOUT_MS=30000
